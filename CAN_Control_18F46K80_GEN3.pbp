A_Queue_rx_D5               var     byte[MAXRS485RXQUEUE]
A_Queue_rx_D6               var     byte[MAXRS485RXQUEUE]
A_Queue_rx_D7               var     byte[MAXRS485RXQUEUE]
A_Queue_rx_SIDH             var     byte[MAXRS485RXQUEUE]
A_Queue_rx_SIDL             var     byte[MAXRS485RXQUEUE]
