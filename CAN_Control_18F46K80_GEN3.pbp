'Firmware to be used with the OpenMotics Can Control in combination with Core or Core+

'Written in Pic Basic Pro 2.6 however it should be compatible with Pic Basic Pro 3.0 but this is not yet tested
'Interrupt system of Darrel Taylor is used see http://darreltaylor.com/DT_INTS-18/home.html
'For more information see wiki.openmotics.com

'ONLY WORKS WITH GEN3 HW and ONLY CORE/CORE+!!!

@ CONFIG SOSCSEL=DIG

'------------------Constants----------------------------------------------------
VERSION                 con         6
FIRMWARE                con         0
BUILT                   con         35

hardware                con         4

MAXRS485RXQUEUE         con         100
MAXRS485TXQUEUE         con         100
MAXRS485LENGTH          con         11  'Max length (in RS485 message) that can be used. Cannot be increased without changing variables A_Queue_...

SENT_START              con         0
REPEATED_START          con         1
SENT_ADDRESS_W          con         2
SENT_ADDRESS_R          con         3
CHECK_ACK               con         4
SENT_COMMANDCODE        con         5
SENT_COMMANDDATA        con         6
SENT_COMMANDDATA1       con         7
SENT_COMMANDDATA2       con         8
SENT_COMMANDDATA3       con         9
SENT_ACK                con         10
SENT_NACK               con         11
SENT_STOP               CON         12
CHECK_INTERRUPT         con         13
ENABLE_RECEIVING        con         14
RECEIVE_DATA            con         15
PROCESS_DONE            con         16
SET_WAITTIME_1MS        con         17
SET_WAITTIME_10MS       con         18
WAIT_NOW                con         19

MAXI2CBYTES             con         5
MAXI2CSTEPS             con         45

UPDATELEDS              con         0
READINPUT               con         1
READRS485               con         2
BLOCKINGI2C             con         7

MAXSTATEMACHINES        con         8
MAX_RS485_MESSAGES      con         1       'Max RS485 messages towards Master in 1 communication flow (Max is 8)

START                   con         0
STEP1                   con         1
STEP2                   con         2
STEP3                   con         3
STEP4                   con         4
STEP5                   con         5
STEP6                   con         6
STEP7                   con         7
STEP8                   con         8
STEP9                   con         9
STEP10                  con         10

PRESSED                 con         0
RELEASED                con         1

BROADCASTMESSAGE        con         0
CANCONTROLMESSAGE       con         1
ACTIVATEDEVICEMESSAGE   con         2

EMPTY_MESSAGE           con         0
CAN_MESSAGE             con         1
DALI_MESSAGE            con         2

TCA9539_0_ADDRESS       con         %11101011  'Chip for leds and buttons 6T and 37
TCA9539_1_ADDRESS       con         %11101101  'Chip for leds 6T
TCA9539_2_ADDRESS       con         %11101110
TCA9539_3_ADDRESS       con         %11101100
PCF8574_ADDRESS         con         %01000000
PCF8574A_ADDRESS        con         %01110000
LM75_ADDRESS            con         %10011110
FM24C04_ADDRESS         con         %10100100   'FRAM
F24FC1025_ADDRESS       con         %10101010
M24C02_ADDRESS          con         %10101100   'Small eeprom for serial address etc 

BUFFER_UART_RX          con         180
YES                     con         1
NO                      con         0
OK                      con         1
NOK                     con         0
LED_OFF                 con         0
LED_ON                  con         1
BLINK_ON                con         1
BLINK_OFF               con         0
TCA9539_FOUND           var         ic_found.bit0
SMALL_EEPROM_FOUND      var         ic_found.bit1
LARGE_EEPROM_FOUND      var         ic_found.bit2
FRAM_FOUND              var         ic_found.bit3
LM75_FOUND              var         ic_found.bit4
LED_STATUS_RED          VAR         led_data.bit9
LED_STATUS_GREEN        var         led_data.bit10
LED_CANBUS_RED          var         led_data.bit7
LED_CANBUS_GREEN        var         led_data.bit8
LED_CANCOM              var         led_data.bit0

LED_STATUS_RED_BLINK    VAR         led_data_blink.bit9
LED_STATUS_GREEN_BLINK  var         led_data_blink.bit10
LED_CANBUS_RED_BLINK    var         led_data_blink.bit7
LED_CANBUS_GREEN_BLINK  var         led_data_blink.bit8
LED_CANCOM_BLINK        var         led_data_blink.bit0


'------------Includes----------------------------
include "PIC18CAN.bas"

DEFINE  USE_LOWPRIORITY     1
define  NO_CLRWDT           1   ; No automatic clear watchdog timer
INCLUDE "DT_INTS-18F45K80.bas"  ; Base Interrupt System
INCLUDE "ReEnterPBP-18.bas"     ; Include if using PBP interrupts
INCLUDE "ReEnterPBP-18LP.bas"   ; Include if using Low Pr. PBP INTS

CLEARWDT

' -------- Hardware configuration ------------------------------------------------------
ANCON0=%00000000   'All ports configured as digital ports
ANCON1=%00000000   'All ports configured as digital ports
TRISA=%00111111
TRISB=%11101011
TRISC=%10111101
TRISD=%11001111
TRISE=%11111001

RS485_DIR               var         PORTD.4     'Mode for RS485 chip (send or receive)
RESET_PIN               VAR         PORTE.2     'Reset pin of TCA9538 (gnd to reset)
INTERRUPT_PIN           VAR         PORTE.1     'Interrupt pin from TCA9538
CAN_POWER_OUT           var         PORTD.5     'Switch ON/OFF power CAN bus (High=ON)
OUTPUT_SEL              var         PORTA.0     'Pin that selects between RS232 OUT or UART out via debug pin (HIGH=debug pin)

output                  RS485_DIR
low                     RS485_DIR
input                   PORTC.7
output                  PORTC.6
output                  RESET_PIN 
high                    RESET_PIN 
INPUT                   INTERRUPT_PIN
OUTPUT                  OUTPUT_SEL
high                    OUTPUT_SEL              'HIGH->Debug pin is selected, LOW->RS232 TXD is selected
OUTPUT                  CAN_POWER_OUT      

'--------40Mhz (external xtal 10Mhz PLL to 40Mhz------------------
' For PBP2.6 (not for 3.0) please modify 18F45K80.inc (in directory /PBP)
' Modification: CONFIG FOSC = HS1
DEFINE              OSC     40
OSCCON.0=0                          'external oscillator
OSCCON.1=0
OSCTUNE.6=1                         'PLL enabled
BAUDCON1.5=0                        'receive data is not inverted
BAUDCON1.3=1                        'BRG16=1
BAUDCON1.4=0                        'idle state for Txd is 1
SPBRGH1 = 0                         '115200 baud
SPBRG1 = 86
RCSTA1 = %00010000
TXSTA1 = %00000100
'BAUDCON2.5=0                        'receive data is not inverted
'BAUDCON2.3=1                        'BRG16=1
'BAUDCON2.4=0                        'idle state for Txd is 1
'SPBRGH2 = 1                         '38400 baud
'SPBRG2 = 3
'RCSTA2 = %00010000
'TXSTA2 = %00000100
BAUDCON2.5=0                        'receive data is not inverted
BAUDCON2.3=1                        'BRG16=1
BAUDCON2.4=0                        'idle state for Txd is 1
SPBRGH2 = 0                         '115200 baud
SPBRG2 = 86
RCSTA2 = %00010000
TXSTA2 = %00000100
T0CON=%10000010                 ; T0 = 16-bit, 1:8 Prescaler
T2CON=%00111100
T4CON=%01111011                     'Interrupt every 6.5ms
SSPADD.0=0  
SSPADD.1=0
SSPADD.2=0
SSPADD.3=1
SSPADD.4=1
SSPADD.5=0
SSPADD.6=0
SSPCON1=%00101000                   'turn on MSSP and set for master mode i2c
SSPSTAT.7=1                         'Slew rate off 
CCP2CON=0

